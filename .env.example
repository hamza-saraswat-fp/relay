# ── Supabase (read-store; service role only — the browser never talks to Supabase) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Salesforce integration user / Connected App (IAI-236 — from Saffi) ──
# Read-only data sync (Case + EmailMessage). The link field write is owned by the
# Salesforce case-create automation, so this user needs no write scope.
SF_INSTANCE_URL=
SF_CLIENT_ID=
SF_CLIENT_SECRET=

# Static bearer key the SF case-create automation presents to /api/salesforce/case-created
# (onboarding-app pattern; generate with `openssl rand -hex 32`). IAI-237.
SALESFORCE_INTEGRATION_KEY=

# ── OpenRouter — Claude Sonnet 5 (latest-update cleaning + safety pass, IAI-214) ──
OPENROUTER_API_KEY=

# ── Sync triggers ──
# Manual refresh: POST /api/sync with header `x-relay-sync-key: $RELAY_SYNC_KEY`
RELAY_SYNC_KEY=
# Vercel Cron: Vercel sends GET /api/sync with `Authorization: Bearer $CRON_SECRET`
CRON_SECRET=

# ── Observability (IAI-239) ──
# Slack incoming webhook — sync failures POST here. Unset = alerting no-ops (dev/local stay silent).
# Health check: GET /api/health (auth header `x-relay-sync-key: $RELAY_SYNC_KEY`) → 200 healthy / 503 stale|stuck|error.
SLACK_ALERT_WEBHOOK_URL=

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
