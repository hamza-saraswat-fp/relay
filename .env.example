# ── Supabase (read-store; service role only — the browser never talks to Supabase) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Salesforce integration user / Connected App (IAI-236 — from Saffi) ──
SF_INSTANCE_URL=
SF_CLIENT_ID=
SF_CLIENT_SECRET=

# ── Anthropic (latest-update cleaning + safety pass, IAI-214) ──
ANTHROPIC_API_KEY=

# ── Sync triggers ──
# Manual refresh: POST /api/sync with header `x-relay-sync-key: $RELAY_SYNC_KEY`
RELAY_SYNC_KEY=
# Vercel Cron: Vercel sends GET /api/sync with `Authorization: Bearer $CRON_SECRET`
CRON_SECRET=

# ── Observability ──
SLACK_ALERT_WEBHOOK_URL=

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
